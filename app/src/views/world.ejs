<div class="WorldPage">
    <div class="Main">
        <div class="Title">
            <h1><%= world.name %></h1>
        </div>
        <div class="Info">
            <div class="Description">
                <img src=<%= world.image_path %> alt="Image">
                <div class="Text">
                    <%- include('partials/noteArea', {sectionTitle: 'Description', id: 'description', value: world.description }) %>
                </div>
            </div>    
            <div class="Text">
                <%- include('partials/noteArea', {sectionTitle: 'Notes', id: 'notes', value: world.notes }) %>
            </div>
        </div>
    </div>

    <div class="Links">
        <textarea id="characters" name="characters" placeholder="Links to Characters" style="flex: 1;"></textarea>
        <textarea id="locations" name="locations" placeholder="Links to Locations" style="flex: 1;"></textarea>
        <textarea id="lore" name="lore" placeholder="Links to Lore" style="flex: 1;"></textarea>
    </div>
</div>