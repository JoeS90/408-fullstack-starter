<div class="WorldPage">
    <div class="WorldPage-Main">
        <div class="WorldPage-Title">
            <%- include('partials/titleArea', {
                collectionId: world.id,
                entryType: 'collection',
                entryName: world.name
            }) %>
        </div>
        <div class="WorldPage-Info">
            <div class="WorldPage-Description">
                <%- include('partials/imageArea', {
                    collectionId: world.id,
                    entryId: world.id,
                    entryType: 'collection',
                    imagePath: world.image_path
                }) %>
                <%- include('partials/noteArea', {
                    sectionTitle: 'Description', 
                    id: 'description', 
                    value: world.description,
                    collectionId: world.id,
                    entryId: world.id,
                    entryType: 'collection'
                }) %>
            </div>    
                <%- include('partials/noteArea', {
                    sectionTitle: 'Notes', 
                    id: 'notes', 
                    value: world.notes,
                    collectionId: world.id,
                    entryId: world.id,
                    entryType: 'collection'
                }) %>
        </div>
    </div>

    <div class="WorldPage-Sidebar">
        <div class="WorldPage-Associations">
            <textarea id="characters" name="characters" placeholder="Links to Characters" style="flex: 1;"></textarea>
            <textarea id="locations" name="locations" placeholder="Links to Locations" style="flex: 1;"></textarea>
            <textarea id="lore" name="lore" placeholder="Links to Lore" style="flex: 1;"></textarea>
        </div>
        <div class="WorldPage-Manage">
            <button class="MenuButton" type="button" onclick="deleteWorld('<%= world.id %>', '<%= world.name %>')">Delete</button>
            <button class="MenuButton disabled" disabled title="NotImplemented">Export</button>
        </div>
    </div>
</div>