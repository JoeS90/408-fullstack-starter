<div class="LorePage">
    <div class="LorePage-Main">
        <div class="LorePage-Title">
            <%- include('partials/titleArea', {
            collectionId: entry.collection_id,
            entryId: entry.id,
            entryType: 'lore',
            entryName: entry.name
            }) %>
        </div>
        <div class="LorePage-Info">
            <div class="LorePage-Overview">
                <%- include('partials/imageArea', {
                    collectionId: entry.collection_id,
                    entryId: entry.id,
                    entryType: 'lore',
                    imagePath: entry.image_path
                }) %>
                <%- include('partials/noteArea', {
                    sectionTitle: 'Summary', 
                    id: 'summary', 
                    value: entry.summary,
                    collectionId: entry.collection_id,
                    entryId: entry.id,
                    entryType: 'lore'
                }) %>
            </div>
            <div class="LorePage-Details">
                <%- include('partials/noteArea', {
                    sectionTitle: 'Details', 
                    id: 'details', 
                    value: entry.details,
                    collectionId: entry.collection_id,
                    entryId: entry.id,
                    entryType: 'lore'
                }) %>
            </div>
        </div>
    </div>

    <div class="EntryPage-Sidebar">
        <div class="EntryPage-Sidebar-Head">
            <div class="EntryPage-Sidebar-Title">Affiliations</div>
            <button class="ControlButton" title="Back to World" onclick="location.href='/collection/<%= entry.collection_id %>'">Back to World</button>
        </div>
        <div class="EntryPage-Associations">
            <%- include('partials/associations', {
                id: 'charAssocs', 
                assocTitle: 'Characters',
                collectionId: entry.collection_id,
                entryId: entry.id,
                entryType: 'lore',
                assocType: 'character',
                areaList: relationships.characters
            }) %>
            <%- include('partials/associations', {
                id: 'locAssocs',
                assocTitle: 'Locations',
                collectionId: entry.collection_id,
                entryId: entry.id,
                entryType: 'lore',
                assocType: 'location',
                areaList: relationships.locations
            }) %>
            <%- include('partials/associations', {
                id: 'orgsAssocs', 
                assocTitle: 'Organizations',
                collectionId: entry.collection_id,
                entryId: entry.id,
                entryType: 'lore',
                assocType: 'organization',
                areaList: relationships.organizations
            }) %>
            <%- include('partials/associations', {
                id: 'loreAssocs', 
                assocTitle: 'Lore',
                collectionId: entry.collection_id,
                entryId: entry.id,
                entryType: 'lore',
                assocType: 'lore',
                areaList: relationships.lore
            }) %>
        </div>
        <div class="EntryPage-Manage">
            <button class="ControlButton disabled" disabled title="Not Implemented">Planeshift</button>
            <button class="ControlButton" type="button" onclick="deleteEntry('<%= entry.collection_id %>','<%= entry.id %>', '<%= entry.name %>', 'lore')">Delete</button>
            <button class="ControlButton disabled" disabled title="Not Implemented">Export</button>
        </div>
    </div>
</div>