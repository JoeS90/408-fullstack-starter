<!-- Define the location tree-based association display section -->
<div class="AssocArea"
    id="<%= id %>"
    data-cid="<%= collectionId %>"
    data-eid="<%= entryId %>"
    data-etype="<%= entryType %>"
    data-atype="<%= assocType %>"
>
    <div class="AssocArea-Head">
        <span class="AssocArea-Title"><%= assocTitle %></span>
        <form action="/createAssociation" method="POST" style="display: inline;">
            <input type="hidden" name="collectionId" value="<%= collectionId %>">
            <input type="hidden" name="entryId" value="<%= entryId %>">
            <input type="hidden" name="entryName" value="<%= entryName %>">
            <input type="hidden" name="entryType" value="<%= entryType %>">
            <input type="hidden" name="assocType" value="<%= assocType %>">
            <button class="EditToggle" type="submit">Connect</button>
        </form>
        <form action="/createEntry" method="POST" style="display: inline;">
            <input type="hidden" name="collectionId" value="<%= collectionId %>">
            <input type="hidden" name="entryId" value="<%= entryId %>">
            <input type="hidden" name="entryName" value="<%= entryName %>">
            <input type="hidden" name="entryType" value="<%= entryType %>">
            <input type="hidden" name="assocType" value="<%= assocType %>">
            <button class="EditToggle" type="submit">New</button>
        </form>
    </div>
    <% if (areaList.parent) { %>
        <div class="AssocArea-Entry AssocArea-Parent">
            <div>
                Located in:
                <a href="/location/<%= collectionId %>/<%= areaList.parent.id %>">
                    <%= areaList.parent.name %>
                </a>
            </div>
            <button class="AssocArea-DeleteButton" type="button" onclick="removeParentLocationAssociation(this, '<%= entryId %>')" aria-label="Delete association">X</button>
        </div>
    <% } %>
    <ul class="AssocArea-List">
        <% if (areaList.children && areaList.children.length > 0) { %>
            <% areaList.children.sort((a, b) => a.name.toLowerCase().localeCompare(b.name.toLowerCase())); %>
            <% areaList.children.forEach(rel => { %>
                <li class="AssocArea-Entry">
                    <div>
                        <a href="/<%= assocType %>/<%= collectionId %>/<%= rel.id %>">
                            <%= rel.name %>
                        </a>
                    </div>
                    <button class="AssocArea-DeleteButton" type="button" onclick="removeParentLocationAssociation(this, '<%= rel.id %>')" aria-label="Delete association">X</button>
                </li>
            <% }); %>
        <% } else { %>
            No entries found.
        <% } %>
    </ul>
</div>