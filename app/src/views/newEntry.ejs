<div class="SplashPage">
    <h1>Create new <%= assocType %></h1>
    <h2>Choose a name. (This can be changed later.)</h2>
    <% if (locals.error) { %>
        <p class="ErrorMessage"><%= error %></p>
    <% } %>
    <form action="/addEntry" method="POST">
        <input type="hidden" name="collectionId" value="<%= collectionId %>">
        <input type="hidden" name="entryId" value="<%= entryId %>">
        <input type="hidden" name="entryType" value="<%= entryType %>">
        <input type="hidden" name="assocType" value="<%= assocType %>">
        <input type="text" id="name" name="name" placeholder="Name" required autofocus>
        <% if (entryType !== 'collection') { %>
            <!-- If the new entry is created from an entry, automatically create association -->
            <% if (entryType === 'location' && assocType === 'location') { %>
                <!-- Location-location condition. Determine which element is the parent element? -->
            <% } else if (entryType === 'character' && assocType === 'character') { %>
                <!-- Character-character condition. Option for both. -->
                <div>
                    <%= entryName %> is the 
                    <input type="text" style="margin-left: 2px; margin-right: 2px;" name="E_is_to_A" placeholder="Relationship">
                    of <span id="injectName1"></span>.
                </div>
                <div>
                    <span id="injectName2"></span> is the 
                    <input type="text" style="margin-left: 2px; margin-right: 2px;" name="A_is_to_E" placeholder="Relationship">
                    of <%= entryName %>.
                </div>
            <% } else { %>
                <!-- All other cases have directionally agnostic relationships -->
                <input type="text" name="A_is_to_E" placeholder="Relationship">
            <% } %>
        <% } %>
        <button class="MenuButton" type="submit">Add</button>
        <% if (entryType !== 'collection') { %>
            <button class="MenuButton" type="submit" formaction="/<%= entryType %>/<%= collectionId %>/<%= entryId %>" formnovalidate>Back</button>
        <% } else { %>
            <button class="MenuButton" type="submit" formaction="/collection/<%= collectionId %>" formnovalidate>Back</button>
        <% } %>
    </form>
</div>

<!-- Script to update the names for character-character relationships. Provides clarity for directional associations. -->
<script>
    const textInput = document.getElementById('name');
    const name1 = document.getElementById('injectName1');
    const name2 = document.getElementById('injectName2');

    function updateName()
    {
        if(!textInput|| !name1 || !name2) {return;}

        name1.textContent = textInput.value;
        name2.textContent = textInput.value;
    }

    updateName();
    textInput.addEventListener('input', updateName);
</script>