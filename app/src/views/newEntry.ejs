<div class="SplashPage">
    <h1>Create new <%= assocType %></h1>
    <h2>Choose a name. (This can be changed later.)</h2>
    <% if (locals.error) { %>
        <p class="ErrorMessage"><%= error %></p>
    <% } %>
    <form action="/addEntry" method="POST">
        <input type="hidden" name="collectionId" value="<%= collectionId %>">
        <input type="hidden" name="entryId" value="<%= entryId %>">
        <input type="hidden" name="entryType" value="<%= entryType %>">
        <input type="hidden" name="assocType" value="<%= assocType %>">
        <input type="text" name="name" placeholder="Name" required autofocus>
        <% if (entryType !== 'collection') { %>
            <input type="text" name="relationship" placeholder="Relationship">
        <% } %>
        <button class="MenuButton" type="submit">Add</button>
    </form>
</div>