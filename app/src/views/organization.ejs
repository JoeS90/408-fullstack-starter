<div class="OrganizationPage">
    <div class="OrganizationPage-Main">
        <div class="OrganizationPage-Info">
            <%- include('partials/titleArea', {
                collectionId: entry.collection_id,
                entryId: entry.id,
                entryType: 'organization',
                entryName: entry.name
            }) %>
            <div class="OrganizationPage-Details">
                <div class="OrganizationPage-Overview">
                    <%- include('partials/imageArea', {
                        collectionId: entry.collection_id,
                        entryId: entry.id,
                        entryType: 'organization',
                        imagePath: entry.image_path
                    }) %>
                    <%- include('partials/noteArea', {
                        sectionTitle: 'Overview', 
                        id: 'overview', 
                        value: entry.overview,
                        collectionId: entry.collection_id,
                        entryId: entry.id,
                        entryType: 'organization'
                    }) %>
                </div>
                <div class="OrganizationPage-Hierarchy">
                    <%- include('partials/noteArea', {
                        sectionTitle: 'Hierarchy', 
                        id: 'hierarchy', 
                        value: entry.hierarchy,
                        collectionId: entry.collection_id,
                        entryId: entry.id,
                        entryType: 'organization'
                    }) %>
                </div>
            </div>
        </div>
        <div class="OrganizationPage-Background">
            <%- include('partials/noteArea', {
                sectionTitle: 'History', 
                id: 'history', 
                value: entry.history,
                collectionId: entry.collection_id,
                entryId: entry.id,
                entryType: 'organization'
            }) %>
            <%- include('partials/noteArea', {
                sectionTitle: 'Notes', 
                id: 'notes', 
                value: entry.notes,
                collectionId: entry.collection_id,
                entryId: entry.id,
                entryType: 'organization'
            }) %>
        </div>
    </div>

    <div class="EntryPage-Sidebar">
        <div class="EntryPage-Sidebar-Head">
            <div class="EntryPage-Sidebar-Title">Affiliations</div>
            <button class="ControlButton" title="Back to World" onclick="location.href='/collection/<%= entry.collection_id %>'">Back to World</button>
        </div>
        <div class="EntryPage-Associations">
            <%- include('partials/associations', {
                id: 'charAssocs', 
                assocTitle: 'Characters',
                collectionId: entry.collection_id,
                entryId: entry.id,
                entryName: entry.name,
                entryType: 'organization',
                assocType: 'character',
                areaList: relationships.characters
            }) %>
            <%- include('partials/associations', {
                id: 'locAssocs',
                assocTitle: 'Locations',
                collectionId: entry.collection_id,
                entryId: entry.id,
                entryName: entry.name,
                entryType: 'organization',
                assocType: 'location',
                areaList: relationships.locations
            }) %>
            <%- include('partials/associations', {
                id: 'orgsAssocs', 
                assocTitle: 'Organizations',
                collectionId: entry.collection_id,
                entryId: entry.id,
                entryName: entry.name,
                entryType: 'organization',
                assocType: 'organization',
                areaList: relationships.organizations
            }) %>
            <%- include('partials/associations', {
                id: 'loreAssocs', 
                assocTitle: 'Lore',
                collectionId: entry.collection_id,
                entryId: entry.id,
                entryName: entry.name,
                entryType: 'organization',
                assocType: 'lore',
                areaList: relationships.lores
            }) %>
        </div>
        <div class="EntryPage-Manage">
            <button class="ControlButton disabled" disabled title="Not Implemented">Planeshift</button>
            <button class="ControlButton" type="button" onclick="deleteEntry('<%= entry.collection_id %>','<%= entry.id %>', '<%= entry.name %>', 'organization')">Delete</button>
            <button class="ControlButton disabled" disabled title="Not Implemented">Export</button>
        </div>
    </div>
</div>